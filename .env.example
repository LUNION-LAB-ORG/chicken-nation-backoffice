# Public URL of the deployed backoffice (used for SEO, OG tags, etc.)
NEXT_PUBLIC_URL=""

# Backend API
# Production : https://api.chicken-nation.com
# Staging    : https://api-staging.chicken-nation.com
# Legacy     : https://chicken.turbodeliveryapp.com
NEXT_PUBLIC_API_URL=""
NEXT_PUBLIC_API_PREFIX="/api/v1"

# AWS CloudFront — CDN for media (S3 bucket)
NEXT_PUBLIC_CLOUDFRONT_URL=""

# Google Maps API key (delivery zones, restaurant location)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# OneSignal — web push notifications
NEXT_PUBLIC_ONESIGNAL_APP_ID=""

# === Docker compose only ===
# Bind interface (127.0.0.1 = local only via nginx reverse-proxy ; 0.0.0.0 = public)
HOST_BIND=127.0.0.1
HOST_PORT=3000
